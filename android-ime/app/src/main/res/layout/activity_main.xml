<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D1B2A">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="24dp"
        android:paddingBottom="32dp">

        <!-- ══ 標題列 ══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="24dp">

            <ImageView
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:src="@mipmap/ic_launcher_round"
                android:contentDescription="App Icon" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="小企鵝嘸蝦米輸入法"
                    android:textColor="#E2E8F0"
                    android:textStyle="bold"
                    android:textSize="20sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="功能設定"
                    android:textColor="#64748B"
                    android:textSize="13sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- ══ 區塊 1：啟用輸入法 ══ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="啟用輸入法"
            android:textColor="#34D399"
            android:textSize="12sp"
            android:textStyle="bold"
            android:letterSpacing="0.08"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#131F2E"
            android:padding="4dp"
            android:layout_marginBottom="20dp">

            <Button
                android:id="@+id/btn_enable_ime"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@android:color/transparent"
                android:gravity="start|center_vertical"
                android:paddingStart="16dp"
                android:text="① 前往系統設定 → 開啟本輸入法"
                android:textColor="#CBD5E1"
                android:textSize="14sp" />

            <View android:layout_width="match_parent" android:layout_height="1dp"
                  android:background="#1E2D3D" android:layout_marginStart="16dp"/>

            <Button
                android:id="@+id/btn_switch_ime"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@android:color/transparent"
                android:gravity="start|center_vertical"
                android:paddingStart="16dp"
                android:text="② 切換至本輸入法"
                android:textColor="#CBD5E1"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- ══ 區塊 2：詞庫管理 ══ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="詞庫管理"
            android:textColor="#34D399"
            android:textSize="12sp"
            android:textStyle="bold"
            android:letterSpacing="0.08"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#131F2E"
            android:padding="4dp"
            android:layout_marginBottom="20dp">

            <!-- 造詞 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="造詞 / 加字"
                android:textColor="#94A3B8"
                android:textSize="12sp"
                android:paddingStart="16dp"
                android:paddingTop="12dp"
                android:paddingBottom="4dp"/>

            <EditText
                android:id="@+id/edit_word"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp"
                android:hint="字 / 詞（例：測試）"
                android:textColor="#E2E8F0"
                android:textColorHint="#475569"
                android:textSize="15sp"
                android:background="#1E2D3D"
                android:paddingStart="12dp"
                android:inputType="text" />

            <EditText
                android:id="@+id/edit_code"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp"
                android:layout_marginTop="6dp"
                android:hint="字根（例：cs）"
                android:textColor="#E2E8F0"
                android:textColorHint="#475569"
                android:textSize="15sp"
                android:background="#1E2D3D"
                android:paddingStart="12dp"
                android:inputType="text" />

            <Button
                android:id="@+id/btn_add_word"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="4dp"
                android:background="#0F3D2E"
                android:text="加入詞庫（立即生效）"
                android:textColor="#34D399"
                android:textSize="14sp" />

            <View android:layout_width="match_parent" android:layout_height="1dp"
                  android:background="#1E2D3D" android:layout_marginStart="16dp"
                  android:layout_marginTop="4dp"/>

            <!-- 匯出 / 匯入 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="4dp">

                <Button
                    android:id="@+id/btn_export_dict"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="52dp"
                    android:background="@android:color/transparent"
                    android:text="📤 匯出備份"
                    android:textColor="#94A3B8"
                    android:textSize="13sp" />

                <View android:layout_width="1dp" android:layout_height="match_parent"
                      android:background="#1E2D3D"/>

                <Button
                    android:id="@+id/btn_import_dict"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="52dp"
                    android:background="@android:color/transparent"
                    android:text="📥 匯入備份"
                    android:textColor="#94A3B8"
                    android:textSize="13sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/txt_dict_path"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#475569"
                android:textSize="11sp"
                android:paddingStart="16dp"
                android:paddingBottom="8dp"/>
        </LinearLayout>

        <!-- ══ 區塊 3：鍵盤外觀 ══ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="鍵盤外觀"
            android:textColor="#34D399"
            android:textSize="12sp"
            android:textStyle="bold"
            android:letterSpacing="0.08"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#131F2E"
            android:padding="4dp"
            android:layout_marginBottom="20dp">

            <!-- 快捷鍵列開關 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="顯示快捷鍵列"
                        android:textColor="#CBD5E1"
                        android:textSize="14sp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="AI、符號、語音、剪貼簿等工具圖示"
                        android:textColor="#475569"
                        android:textSize="11sp" />
                </LinearLayout>
                <Switch
                    android:id="@+id/switch_toolbar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    android:thumbTint="#34D399"
                    android:trackTint="#0F3D2E" />
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                  android:background="#1E2D3D" android:layout_marginStart="16dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="主題配色"
                android:textColor="#94A3B8"
                android:textSize="12sp"
                android:paddingStart="16dp"
                android:paddingTop="12dp"
                android:paddingBottom="8dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp"
                android:layout_marginBottom="4dp"
                android:gravity="center_vertical">

                <Button
                    android:id="@+id/btn_theme_dark"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="44dp"
                    android:layout_marginEnd="6dp"
                    android:background="#1E2D3D"
                    android:text="🌑 深色"
                    android:textColor="#E2E8F0"
                    android:textSize="13sp" />

                <Button
                    android:id="@+id/btn_theme_light"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="44dp"
                    android:layout_marginEnd="6dp"
                    android:background="#1E2D3D"
                    android:text="☀️ 淺色"
                    android:textColor="#E2E8F0"
                    android:textSize="13sp" />

                <Button
                    android:id="@+id/btn_theme_matcha"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="44dp"
                    android:background="#1E2D3D"
                    android:text="🍵 抹茶"
                    android:textColor="#E2E8F0"
                    android:textSize="13sp" />
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                  android:background="#1E2D3D" android:layout_marginStart="16dp"
                  android:layout_marginTop="8dp"/>

            <TextView
                android:id="@+id/txt_scale"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="鍵高 100%　字級 100%"
                android:textColor="#94A3B8"
                android:textSize="12sp"
                android:paddingStart="16dp"
                android:paddingTop="12dp"
                android:paddingBottom="4dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp"
                android:layout_marginBottom="12dp">

                <Button android:id="@+id/btn_key_minus"
                    android:layout_width="0dp" android:layout_weight="1"
                    android:layout_height="42dp" android:layout_marginEnd="4dp"
                    android:background="#1E2D3D" android:text="鍵高 −"
                    android:textColor="#94A3B8" android:textSize="12sp"/>

                <Button android:id="@+id/btn_key_plus"
                    android:layout_width="0dp" android:layout_weight="1"
                    android:layout_height="42dp" android:layout_marginEnd="4dp"
                    android:background="#1E2D3D" android:text="鍵高 +"
                    android:textColor="#94A3B8" android:textSize="12sp"/>

                <Button android:id="@+id/btn_text_minus"
                    android:layout_width="0dp" android:layout_weight="1"
                    android:layout_height="42dp" android:layout_marginEnd="4dp"
                    android:background="#1E2D3D" android:text="字級 −"
                    android:textColor="#94A3B8" android:textSize="12sp"/>

                <Button android:id="@+id/btn_text_plus"
                    android:layout_width="0dp" android:layout_weight="1"
                    android:layout_height="42dp"
                    android:background="#1E2D3D" android:text="字級 +"
                    android:textColor="#94A3B8" android:textSize="12sp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- ══ 區塊 4：AI 問答設定 ══ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AI 問答設定"
            android:textColor="#34D399"
            android:textSize="12sp"
            android:textStyle="bold"
            android:letterSpacing="0.08"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#131F2E"
            android:padding="4dp"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="長按鍵盤 AI✦ 鍵開啟問答面板（支援附圖）"
                android:textColor="#64748B"
                android:textSize="12sp"
                android:paddingStart="16dp"
                android:paddingTop="10dp"
                android:paddingBottom="6dp"/>

            <EditText
                android:id="@+id/edit_gemini_key"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp"
                android:hint="Gemini API Key（AIza...）"
                android:textColor="#E2E8F0"
                android:textColorHint="#475569"
                android:textSize="14sp"
                android:background="#1E2D3D"
                android:paddingStart="12dp"
                android:inputType="textPassword" />

            <Button
                android:id="@+id/btn_save_gemini_key"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="8dp"
                android:background="#0F3D2E"
                android:text="儲存 API Key"
                android:textColor="#34D399"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- 版本資訊 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="8dp"
            android:text="小企鵝嘸蝦米輸入法 v0.1.0"
            android:textColor="#334155"
            android:textSize="11sp" />

    </LinearLayout>
</ScrollView>
